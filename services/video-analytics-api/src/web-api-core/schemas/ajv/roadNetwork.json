{
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "city":{
            "type": "string",
            "minLength": 1,
            "maxLength": 10000,
            "errorMessage": {
                "minLength": "city should have atleast 1 character.",
                "maxLength": "city should have atmost 10000 characters."
            }
        },
        "docType": {
            "type": "string",
            "enum": [
                "roadNetwork"
            ],
            "errorMessage":{
                "enum": "docType must have the value: 'roadNetwork'."
            }
        },
        "intersections": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "name":{
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 10000,
                        "errorMessage": {
                            "minLength": "name should have atleast 1 character.",
                            "maxLength": "name should have atmost 10000 characters."
                        }
                    },
                    "segments":{
                        "type": "array",
                        "minItems": 0,
                        "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "id":{
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100000,
                                    "errorMessage": {
                                        "minLength": "id should have atleast 1 character.",
                                        "maxLength": "id should have atmost 100000 characters."
                                    }
                                },
                                "direction":{
                                    "type": "string",
                                    "enum": [
                                        "E", "W", "N", "S"
                                    ],
                                    "errorMessage":{
                                        "enum": "direction must be one of the following values: 'E', 'W', 'N', 'S'."
                                    }
                                },
                                "start":{
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                        "lat": {
                                            "type": "number",
                                            "minimum": -90,
                                            "maximum": 90,
                                            "errorMessage": {
                                                "minimum": "lat can have a minimum value of -90.",
                                                "maximum": "lat can have a maximum value of 90."
                                            }
                                        },
                                        "lon": {
                                            "type": "number",
                                            "minimum": -180,
                                            "maximum": 180,
                                            "errorMessage": {
                                                "minimum": "lon can have a minimum value of -180.",
                                                "maximum": "lon can have a maximum value of 180."
                                            }
                                        },
                                        "alt": {
                                            "type": "number"
                                        }
                                    },
                                    "required": [
                                        "lat",
                                        "lon"
                                    ]
                                },
                                "end": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                        "lat": {
                                            "type": "number",
                                            "minimum": -90,
                                            "maximum": 90,
                                            "errorMessage": {
                                                "minimum": "lat can have a minimum value of -90.",
                                                "maximum": "lat can have a maximum value of 90."
                                            }
                                        },
                                        "lon": {
                                            "type": "number",
                                            "minimum": -180,
                                            "maximum": 180,
                                            "errorMessage": {
                                                "minimum": "lon can have a minimum value of -180.",
                                                "maximum": "lon can have a maximum value of 180."
                                            }
                                        },
                                        "alt": {
                                            "type": "number"
                                        }
                                    },
                                    "required": [
                                        "lat",
                                        "lon"
                                    ]
                                },
                                "points":{
                                    "type": "array",
                                    "minItems": 2,
                                    "items": {
                                        "type": "object",
                                        "additionalProperties": false,
                                        "properties": {
                                            "lat": {
                                                "type": "number",
                                                "minimum": -90,
                                                "maximum": 90,
                                                "errorMessage": {
                                                    "minimum": "lat can have a minimum value of -90.",
                                                    "maximum": "lat can have a maximum value of 90."
                                                }
                                            },
                                            "lon": {
                                                "type": "number",
                                                "minimum": -180,
                                                "maximum": 180,
                                                "errorMessage": {
                                                    "minimum": "lon can have a minimum value of -180.",
                                                    "maximum": "lon can have a maximum value of 180."
                                                }
                                            },
                                            "alt": {
                                                "type": "number"
                                            }
                                        },
                                        "required": [
                                            "lat",
                                            "lon",
                                            "alt"
                                        ]
                                    }
                                }
                            },
                            "required": [
                                "id",
                                "direction",
                                "start",
                                "end",
                                "points"
                            ]
                        }
                    }
                },
                "required": [
                    "name",
                    "segments"
                ]
            }
        }
    },
    "required": [
        "city",
        "docType",
        "intersections"
    ]
}